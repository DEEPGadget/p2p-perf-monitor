# p2p-perf-monitor — 환경변수 템플릿
# 실제 값을 .env 에 복사 후 채울 것 (.env 는 git ignored)
# 정본 안내 → CLAUDE.md §환경변수, .claude/rules/security.md §SSH

# ─── SSH 접근 (관리망 IP) ───
# controller 가 측정 명령을 SSH 로 트리거할 때 사용. 관리망(192.168.1.x).
SERVER_A_HOST=192.168.1.166     # dg5W-H200NVL-4 SSH IP
SERVER_B_HOST=192.168.1.204     # dg5R-PRO6000SE-8 SSH IP
SSH_USER=deepgadget
# 일반 사용자가 읽을 수 있는 경로 (~/.ssh). Docker 운영 시 컨테이너에 read-only 마운트
SSH_KEY_PATH=~/.ssh/p2p_monitor_ed25519
SSH_KNOWN_HOSTS=~/.ssh/known_hosts_p2p
# 초기 1회 setup 시 패스워드(deepgadget)로 ssh-copy-id 실행 후 키 인증 전환
# scripts/install.sh 가 자동 처리. .env 에 PW 저장 금지

# ─── RDMA 망 IP (RoCE/IB 측정용, perftest 명령 인자) ───
# SSH IP 와 별도 — 다른 서브넷(25.47.1.x).
SERVER_A_RDMA_IP=25.47.1.10     # dg5W-H200NVL-4 RDMA IP (interface enp2s0f0np0)
SERVER_B_RDMA_IP=25.47.1.11     # dg5R-PRO6000SE-8 RDMA IP (interface ens7f0np0)

# ─── RDMA 디바이스 (ConnectX-6 200G 2-port, 1-port만 사용, RoCE 모드) ───
# perftest 는 ibv_devices 가 노출하는 ibv device 명만 인식 — 양쪽 mlx5_0.
# (netdev udev 명칭과는 별개: dg5W=enp2s0f0np0, dg5R=ens7f0np0)
NIC_DEVICE_A=mlx5_0             # dg5W (interface enp2s0f0np0)
NIC_DEVICE_B=mlx5_0             # dg5R (interface ens7f0np0)

# ─── netdev 인터페이스 (sysfs 카운터 폴링 / 트랜시버 ethtool -m) ───
SERVER_A_NETDEV=enp2s0f0np0
SERVER_B_NETDEV=ens7f0np0

# ─── RoCE / RDMA ───
# 서버별 GID 인덱스 분리 — `show_gids` 출력의 RoCE v2 IPv4 행 INDEX
# dg5W: 25.47.1.10 → mlx5_0 INDEX 3 (v2)
# dg5R: 25.47.1.11 → mlx5_0 INDEX 5 (v2)
RDMA_GID_INDEX_A=3
RDMA_GID_INDEX_B=5
RDMA_MTU=9000

# ─── 측정 도구 카테고리 default ───
# (API body 의 tool 필드는 서브툴: ib_write_bw / ib_read_lat / iperf3 / mock)
MEASUREMENT_TOOL=perftest       # perftest | iperf3 | mock

# ─── FastAPI 바인드 ───
BIND_HOST=0.0.0.0
BIND_PORT=8080

# ─── 개발 모드 ───
DEV_CORS=0                      # 1 = localhost:5173 CORS 허용 (Vite dev)
LOG_LEVEL=INFO
