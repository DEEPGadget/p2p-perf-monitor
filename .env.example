# p2p-perf-monitor — 환경변수 템플릿
# 실제 값을 .env 에 복사 후 채울 것 (.env 는 git ignored)
# 정본 안내 → CLAUDE.md §환경변수, .claude/rules/security.md §SSH

# ─── SSH 접근 ───
SERVER_A_HOST=                  # 사용자 제공 — Server A (dg5W-H200NVL-4) 고정 IP
SERVER_B_HOST=                  # 사용자 제공 — Server B (dg5R-PRO6000SE-10) 고정 IP
SSH_USER=deepgadget
SSH_KEY_PATH=/etc/p2p-monitor/id_ed25519
SSH_KNOWN_HOSTS=/etc/p2p-monitor/known_hosts

# ─── NIC (ConnectX-7 200G 2-port, 1-port만 사용, 양쪽 서버 동일) ───
NIC_DEVICE_A=mlx5_0             # 사용자 제공 — mlx5_0 또는 mlx5_1
NIC_DEVICE_B=mlx5_0             # A와 동일

# ─── RoCE / RDMA ───
RDMA_GID_INDEX=3                # Phase 1 시 `show_gids` 로 확정
RDMA_MTU=9000

# ─── 측정 도구 카테고리 default ───
# (API body 의 tool 필드는 서브툴: ib_write_bw / ib_read_lat / iperf3 / mock)
MEASUREMENT_TOOL=perftest       # perftest | iperf3 | mock

# ─── FastAPI 바인드 ───
BIND_HOST=0.0.0.0
BIND_PORT=8080

# ─── 개발 모드 ───
DEV_CORS=0                      # 1 = localhost:5173 CORS 허용 (Vite dev)
LOG_LEVEL=INFO
